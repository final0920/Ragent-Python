# 复制为 .env 后按需修改（.env 已被 .gitignore 忽略）
APP_PORT=9090
APP_CONTEXT_PATH=/api/ragent

# PostgreSQL + pgvector
DATABASE_URL=postgresql+asyncpg://postgres:postgres@127.0.0.1:5432/ragent

# Redis
REDIS_URL=redis://:123456@127.0.0.1:6379/0

# 模型接入（OpenAI 兼容）。默认本地 Ollama，无需 key。
LLM_PROVIDER=ollama
LLM_BASE_URL=http://127.0.0.1:11434/v1
LLM_API_KEY=
LLM_CHAT_MODEL=qwen2.5:7b
EMBEDDING_BASE_URL=http://127.0.0.1:11434/v1
EMBEDDING_API_KEY=
EMBEDDING_MODEL=bge-m3
EMBEDDING_DIM=1024
RERANK_ENABLED=false
RERANK_BASE_URL=
RERANK_API_KEY=
RERANK_MODEL=

# JWT
JWT_SECRET=change-me-in-prod
JWT_EXPIRE_DAYS=30

# RAG 参数
RAG_DENSE_TOPK=20
RAG_SPARSE_TOPK=20
RAG_RRF_K=60
RAG_RERANK_TOPN=5
RAG_HISTORY_KEEP_TURNS=8
RAG_MAX_CONCURRENT=10
RAG_MAX_WAIT_SECONDS=15
RAG_LEASE_SECONDS=600

# P8 MCP（默认关闭）
MCP_ENABLED=false
MCP_SERVER_URL=http://127.0.0.1:9099/mcp

# P1 多模型路由+熔断。LLM_FALLBACKS 为 JSON 数组，缺省字段继承主模型，例：
# LLM_FALLBACKS=[{"model":"qwen2.5:14b","priority":1},{"model":"gpt-4o-mini","base_url":"https://api.openai.com/v1","api_key":"sk-...","priority":2}]
LLM_FALLBACKS=
LLM_FIRST_PACKET_TIMEOUT=60
BREAKER_FAIL_THRESHOLD=2
BREAKER_OPEN_SECONDS=30
